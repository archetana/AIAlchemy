# Google Cloud Storage Configuration for AIAlchemy
# Copy this to .env and fill in your actual values

# Core Application Settings
DEBUG=false
SECRET_KEY=your-super-secure-secret-key-here

# Database Configuration
DATABASE_URL=sqlite:///./aialchemy.db

# Google Cloud Storage Settings (Production)
USE_GOOGLE_CLOUD_STORAGE=true
GOOGLE_CLOUD_STORAGE_BUCKET=aialchemy-uploads-TIMESTAMP
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account-key.json
GOOGLE_CLOUD_PROJECT=your-project-id

# File Upload Settings
LOCAL_UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=500

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,gif,mp4,mov,avi,mp3,wav,m4a

# File size limits by category (in MB)
MAX_DOCUMENT_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=100

# Security Settings
ENABLE_FILE_SCANNING=false
VIRUS_SCAN_TIMEOUT_SECONDS=30

# API Configuration
API_TITLE=AIAlchemy API
API_VERSION=1.0.0
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json