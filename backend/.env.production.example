# AIAlchemy Production Environment Configuration with Google Cloud Storage
# Copy this to .env and fill in your actual values after running GCS setup

# ===== CORE APPLICATION SETTINGS =====
APP_NAME=AIAlchemy
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=your-super-secure-secret-key-here-minimum-32-characters
JWT_SECRET_KEY=your-jwt-secret-key-here-different-from-secret-key

# ===== DATABASE CONFIGURATION =====
DATABASE_URL=postgresql+asyncpg://username:password@host:port/database
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===== REDIS CONFIGURATION =====
REDIS_URL=redis://redis-host:6379/0

# ===== GOOGLE CLOUD CONFIGURATION =====
GOOGLE_CLOUD_PROJECT=your-project-id-here
GOOGLE_APPLICATION_CREDENTIALS=./gcs-service-account-key.json

# Vertex AI Configuration
VERTEX_AI_PROJECT=your-project-id-here
VERTEX_AI_LOCATION=us-central1

# Document AI Configuration (optional)
DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# Dialogflow Configuration (optional)  
DIALOGFLOW_AGENT_ID=your-agent-id

# ===== GOOGLE CLOUD STORAGE SETTINGS =====
USE_GOOGLE_CLOUD_STORAGE=true
GOOGLE_CLOUD_STORAGE_BUCKET=aialchemy-uploads-XXXXXXXXXX
LOCAL_UPLOAD_PATH=./uploads

# ===== FILE UPLOAD CONFIGURATION =====
MAX_UPLOAD_SIZE_MB=500
MAX_FILE_SIZE_MB=100

# File size limits by category (in MB)
MAX_DOCUMENT_SIZE_MB=50
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=100

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,jpg,jpeg,png,gif,mp4,mov,avi,mp3,wav,m4a

# ===== STORAGE BUCKETS =====
BUCKET_APP_STORAGE=aialchemy-uploads-XXXXXXXXXX
BUCKET_ML_MODELS=aialchemy-ml-models
BUCKET_DOCUMENTS=aialchemy-documents

# ===== SECURITY SETTINGS =====
ALLOWED_HOSTS=localhost,127.0.0.1,*.run.app,your-domain.com
CORS_ORIGINS=https://your-frontend-domain.com,https://your-app.run.app

# File security
ENABLE_FILE_SCANNING=false
VIRUS_SCAN_TIMEOUT_SECONDS=30

# ===== EXTERNAL API KEYS =====
GEMINI_API_KEY=your-gemini-api-key
CRUNCHBASE_API_KEY=your-crunchbase-api-key
LINKEDIN_API_KEY=your-linkedin-api-key  
NEWS_API_KEY=your-news-api-key

# ===== FEATURE FLAGS =====
ENABLE_AI_INTERVIEWS=true
ENABLE_REAL_TIME_BENCHMARKING=true
ENABLE_ADVANCED_ANALYTICS=true

# ===== MONITORING =====
ENABLE_MONITORING=true
LOG_LEVEL=INFO

# ===== BACKGROUND TASKS =====
CELERY_BROKER_URL=redis://redis-host:6379/1
CELERY_RESULT_BACKEND=redis://redis-host:6379/2

# ===== JWT CONFIGURATION =====
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24