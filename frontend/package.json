{
  "name": "aialchemy-frontend",
  "version": "1.0.3",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "@mui/material": "^5.15.0",
    "@mui/icons-material": "^5.15.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "recharts": "^2.8.0",
    "axios": "^1.6.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "ESLINT_NO_DEV_ERRORS=true DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "build:production": "npm run version:increment && ESLINT_NO_DEV_ERRORS=true DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:e2e:headless": "playwright test --headless",
    "test:ui": "playwright test --ui",
    "eject": "react-scripts eject",
    "version:increment": "python3 scripts/increment-version.py patch",
    "version:increment:minor": "python3 scripts/increment-version.py minor",
    "version:increment:major": "python3 scripts/increment-version.py major",
    "version:show": "node -e \"const {getVersion} = require('./src/config/version.js'); console.log('Current version:', getVersion());\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
