# AIAlchemy Frontend Environment Configuration

# API Configuration
# For nginx gateway (production): /api
# For local development: http://localhost:8000
REACT_APP_API_BASE_URL=/api
REACT_APP_API_VERSION=v1

# Authentication
REACT_APP_JWT_TOKEN_KEY=aialchemy_token

# Google Services (optional)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id
REACT_APP_GOOGLE_ANALYTICS_ID=your-ga-id

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_REAL_TIME_UPDATES=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# UI Configuration
REACT_APP_THEME_MODE=dark
REACT_APP_PRIMARY_COLOR=#1565C0
REACT_APP_SECONDARY_COLOR=#43A047

# Environment
REACT_APP_ENVIRONMENT=development